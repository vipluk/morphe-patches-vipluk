  <string name="morphe_sb_segments_outro">Ekran końcowy / Napisy</string>
  <string name="morphe_sb_segments_outro_summary">Napisy końcowe lub moment pojawienia się ekranu końcowego. Nie dotyczy merytorycznego podsumowania filmu</string>
  <string name="morphe_sb_segments_hook">Wstęp / Przywitanie</string>
  <string name="morphe_sb_segments_hook_summary">Zapowiedzi nadchodzącego filmu, przywitania i pożegnania. Nie obejmuje sekcji zawierających dodatkową treść</string>
  <string name="morphe_sb_segments_preview">Zapowiedź / Podsumowanie</string>
