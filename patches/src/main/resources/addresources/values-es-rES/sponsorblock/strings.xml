  <string name="morphe_sb_segments_intro">Interrupción / Animación de introducción</string>
  <string name="morphe_sb_segments_intro_summary">Un intervalo sin contenido real. Puede ser una pausa, un fotograma estático o una animación que se repite. No incluye transiciones que contengan información</string>
  <string name="morphe_sb_segments_outro">Tarjetas finales / Créditos</string>
  <string name="morphe_sb_segments_outro_summary">Créditos o cuando aparecen las tarjetas finales de YouTube. No es para conclusiones con información</string>
  <string name="morphe_sb_segments_hook">Enganche / Saludos</string>
  <string name="morphe_sb_segments_hook_summary">Tráileres narrados para el próximo vídeo, saludos y despedidas. No incluye secciones que añadan contenido adicional</string>
  <string name="morphe_sb_segments_preview">Adelanto / Resumen</string>
  <string name="morphe_sb_segments_preview_summary">Colección de clips que muestran lo que está por venir o lo que sucedió en el vídeo o en otros vídeos de una serie, donde toda la información se repite en otra parte</string>
  <string name="morphe_sb_segments_filler">Tangente de relleno / Bromas</string>
  <string name="morphe_sb_segments_filler_summary">Escenas o bromas tangenciales que no son necesarias para entender el contenido principal del vídeo. No incluye segmentos que proporcionen contexto o detalles de fondo</string>
  <string name="morphe_sb_segments_nomusic">Música: sección sin música</string>
